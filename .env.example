# ─────────────────────────────────────────────────────────────
# Supabase — https://supabase.com/dashboard
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─────────────────────────────────────────────────────────────
# Database (Prisma / PostgreSQL)
# DATABASE_URL → Supabase "Transaction" pooler (port 6543)
# DIRECT_URL   → Supabase "Direct connection" (port 5432) — used by Prisma migrations
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ─────────────────────────────────────────────────────────────
# Stripe — https://dashboard.stripe.com
# ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─────────────────────────────────────────────────────────────
# Groq (LLM AI) — https://console.groq.com
# ─────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key

# ─────────────────────────────────────────────────────────────
# Resend (transactional email) — https://resend.com/api-keys
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key

# ─────────────────────────────────────────────────────────────
# App URL (used for Stripe redirect URLs)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://repai.fr
