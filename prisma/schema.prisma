generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  name            String?
  telephone       String?
  company         String?
  plan                 String    @default("free")
  planOverride         Boolean   @default(false)
  planExpiresAt        DateTime?
  planSyncedAt         DateTime?
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  createdAt       DateTime       @default(now())
  // Fitness profile
  birthDate       DateTime?
  heightCm        Int?
  weightKg        Float?
  sex             String?        // "homme" | "femme" | "autre"
  goal            String?        // "prise_de_masse" | "perte_de_poids" | "performance_cardio" | "sante_cardiaque" | "endurance" | "force_max" | "flexibilite" | "maintien" | "bien_etre" | "competition" | "reeducation"
  activityLevel   String?        // "sedentaire" | "leger" | "modere" | "actif" | "tres_actif"
  restingHR       Int?           // fréquence cardiaque au repos
  dailySteps      Int?           // nombre de pas journaliers moyen
  profileComplete  Boolean        @default(false)
  nutritionReco    Json?          // { calories, proteins, carbs, fats, fiber, summary }
  nutritionRecoAt  DateTime?
  workouts         Workout[]
  coachSessions   CoachSession[]
  activities      Activity[]
  meals           Meal[]
  weightEntries   WeightEntry[]
}

model Meal {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  date      DateTime @default(now())
  calories  Int?
  proteins  Float?
  carbs     Float?
  fats      Float?
  fiber     Float?
  notes      String?
  imageThumb String?
  imageUrl   String?
  createdAt  DateTime @default(now())

  @@index([userId, date])
}

model Activity {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String    // "running" | "cycling" | "swimming" | "walking" | "hiking" | "rowing" | "elliptical" | "other"
  name          String
  date          DateTime  @default(now())
  durationSec   Int?
  distanceM     Float?
  elevationM    Float?
  avgHeartRate  Int?
  maxHeartRate  Int?
  calories      Int?
  avgSpeedKmh   Float?
  avgPaceSecKm  Int?
  laps          Int?
  poolLengthM   Int?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, date])
}

model Workout {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  type      String     @default("fullbody")
  notes     String?
  date      DateTime   @default(now())
  exercises Exercise[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Exercise {
  id           String  @id @default(cuid())
  workoutId    String
  workout      Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  name         String
  category     String  @default("strength")
  isUnilateral Boolean @default(false)
  notes        String?
  sets         Set[]
  order        Int     @default(0)
}

model Set {
  id          String   @id @default(cuid())
  exerciseId  String
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  reps        Int?
  weight      Float?
  repsRight   Int?
  weightRight Float?
  duration    Int?
  rpe         Float?
  notes       String?
  order       Int      @default(0)
}

model CoachSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question  String
  response  String
  createdAt DateTime @default(now())
}

model UsageEvent {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "meal_analyzed" | "session_created"
  createdAt DateTime @default(now())

  @@index([userId, type, createdAt])
}

model WeightEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weightKg    Float
  recordedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([userId, recordedAt])
}
